* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: #15202b;
  color: #e7e9ea;
  padding: 24px;
}

.container {
  max-width: 960px;
  margin: 0 auto;
}

h1 {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 20px;
  color: #1d9bf0;
}

h2 {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel {
  background: #192734;
  border: 1px solid #2f3336;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
}

.panel-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  font-weight: 400;
}

.auto-scroll-label {
  font-size: 12px;
  color: #8b98a5;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 4px;
}

.auto-scroll-label input {
  accent-color: #1d9bf0;
}

.small-btn {
  padding: 3px 10px;
  font-size: 11px;
  border: 1px solid #2f3336;
  border-radius: 4px;
  background: transparent;
  color: #8b98a5;
  cursor: pointer;
}

.small-btn:hover {
  background: #2f3336;
  color: #e7e9ea;
}

.tweet-table .small-btn {
  margin-right: 6px;
  margin-bottom: 4px;
}

.tweet-author {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 12px;
  font-weight: 600;
  color: #e7e9ea;
  margin-bottom: 3px;
}

.tweet-text {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 12px;
  line-height: 1.35;
  color: #cfd9de;
  max-width: 420px;
  white-space: normal;
}

.tweet-table a {
  display: inline-block;
  margin-top: 5px;
  color: #1d9bf0;
  text-decoration: none;
}

.tweet-table a:hover {
  text-decoration: underline;
}

/* Health table */
.health-table {
  width: 100%;
  font-size: 13px;
}

.health-table td {
  padding: 4px 0;
}

.health-table .label {
  color: #8b98a5;
  width: 140px;
}

.status-connected { color: #4ade80; }
.status-disconnected { color: #facc15; }
.status-error { color: #f87171; }

.toggle-row {
  margin-top: 12px;
  font-size: 13px;
  color: #8b98a5;
}

.toggle-row label {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
}

.toggle-row input[type="checkbox"] {
  accent-color: #1d9bf0;
}

/* Discovered endpoints */
.discovered-list {
  font-family: "SF Mono", "Menlo", "Monaco", "Consolas", monospace;
  font-size: 12px;
  color: #8b98a5;
}

/* Events table */
.events-wrap {
  max-height: 400px;
  overflow-y: auto;
  border: 1px solid #2f3336;
  border-radius: 4px;
}

.events-table {
