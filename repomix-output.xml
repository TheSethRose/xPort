      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content-bridge.js"],
      "world": "ISOLATED",
      "run_at": "document_start"
    }
