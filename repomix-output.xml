  "name": "XPort",
  "version": "0.23.1",
  "description": "Passively captures tweets from X/Twitter as you browse",
  "permissions": ["storage", "nativeMessaging"],
  "host_permissions": ["*://*.x.com/*", "*://*.twitter.com/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
