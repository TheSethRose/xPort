#!/usr/bin/env python3
"""Read captured XPort tweets from the hosted API or PostgreSQL."""

import argparse
import base64
from collections import Counter
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime, timezone


FIELDS = [
    'tweet_id',
    'author_id',
    'author_username',
    'author_name',
    'text',
    'conversation_id',
    'created_at',
    'captured_at',
    'source_endpoint',
    'url',
    'lang',
    'reply_count',
    'repost_count',
    'like_count',
    'quote_count',
    'bookmark_count',
    'view_count',
    'updated_at',
]


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        result = run(args)
    except XPortError as e:
        print(f'xport: {e}', file=sys.stderr)
        return 1
    write_output(result, jsonl=getattr(args, 'jsonl', False))
    return 0


def build_parser():
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument('--api-url', default=os.environ.get('XPORT_API_URL'), help='XPort API base URL')
    common.add_argument(
        '--token',
        default=os.environ.get('XPORT_API_TOKEN') or os.environ.get('XPORT_INGEST_TOKEN') or os.environ.get('INGEST_TOKEN'),
        help='Bearer token for XPort API reads',
    )
    common.add_argument('--database-url', default=os.environ.get('DATABASE_URL'), help='PostgreSQL DATABASE_URL for direct reads')
    common.add_argument('--include-raw', action='store_true', help='Include raw tweet JSONB')
    common.add_argument('--include-media', action='store_true', help='Include captured media metadata')
    common.add_argument('--jsonl', action='store_true', help='Emit one JSON object per line')

    parser = argparse.ArgumentParser(prog='xport', description='Read tweets captured by XPort.')
    subparsers = parser.add_subparsers(dest='command', required=True)

    search = subparsers.add_parser('search', parents=[common], help='Search captured tweets')
    search.add_argument('query', nargs='?', help='Text to search in tweet text/raw JSON')
    add_filters(search)

    recent = subparsers.add_parser('recent', parents=[common], help='List recent captured tweets')
    add_filters(recent)

    digest = subparsers.add_parser('digest', parents=[common], help='Package captured tweets for an agent-written topic digest')
    add_filters(digest, default_limit=500)

    get = subparsers.add_parser('get', parents=[common], help='Fetch one tweet by ID')
    get.add_argument('tweet_id')

    media = subparsers.add_parser('media', parents=[common], help='List captured media for one tweet')
    media.add_argument('tweet_id')

    transcribe = subparsers.add_parser('transcribe', parents=[common], help='Queue on-demand video transcription through the local daemon')
    transcribe.add_argument('media_id')
    transcribe.add_argument('--daemon-url', default=os.environ.get('XPORT_DAEMON_URL', 'http://127.0.0.1:17381'))
    transcribe.add_argument('--daemon-token', default=os.environ.get('XPORT_DAEMON_TOKEN'))

    content = subparsers.add_parser('media-content', parents=[common], help='Read already-stored media content')
    content.add_argument('media_id')
    content.add_argument('--data-url', action='store_true', help='Return a data URL for stored image bytes')

    subparsers.add_parser('stats', parents=[common], help='Summarize stored tweet coverage')
    return parser


def add_filters(parser, default_limit=50):
    parser.add_argument('--author', help='Author username, with or without @')
    parser.add_argument('--since', help='Lower bound for created_at/captured_at')
    parser.add_argument('--until', help='Upper bound for created_at/captured_at')
    parser.add_argument('--endpoint', help='Source GraphQL endpoint')
    parser.add_argument('--limit', type=int, default=default_limit)
    parser.add_argument('--offset', type=int, default=0)


def run(args):
    if args.api_url:
        return run_api(args)
    if args.database_url:
        return run_db(args)
    raise XPortError('set --api-url or --database-url, or export XPORT_API_URL or DATABASE_URL')


def run_api(args):
    if not args.token:
        raise XPortError('set --token or export XPORT_API_TOKEN/XPORT_INGEST_TOKEN')

    if args.command == 'get':
        payload = request_api(args.api_url, args.token, f'/api/tweets/{urllib.parse.quote(args.tweet_id, safe="")}', {
            'include_raw': args.include_raw,
            'include_media': args.include_media,
        })
        return payload.get('tweet')
    if args.command == 'media':
        return request_api(args.api_url, args.token, f'/api/tweets/{urllib.parse.quote(args.tweet_id, safe="")}/media', {}).get('media', [])
    if args.command == 'media-content':
        if not args.data_url:
            raise XPortError('media-content currently requires --data-url')
        return request_api(args.api_url, args.token, f'/api/media/{urllib.parse.quote(args.media_id, safe="")}/content', {
            'data_url': True,
        })
    if args.command == 'transcribe':
        return transcribe_api_media(args)
    if args.command == 'stats':
        return request_api(args.api_url, args.token, '/api/stats', {}).get('stats')

    params = {
        'q': args.query if args.command == 'search' else None,
        'author': args.author,
        'since': args.since,
        'until': args.until,
        'endpoint': args.endpoint,
        'limit': args.limit,
        'offset': args.offset,
        'include_raw': args.include_raw,
        'include_media': args.include_media,
    }
    tweets = request_api(args.api_url, args.token, '/api/tweets', params).get('tweets', [])
    if args.command == 'digest':
        return build_digest(tweets, args)
    return tweets


def request_api(api_url, token, path, params):
    clean_params = {k: v for k, v in params.items() if v not in (None, False, '')}
    url = api_url.rstrip('/') + path
    if clean_params:
        url += '?' + urllib.parse.urlencode(clean_params)
    req = urllib.request.Request(url, method='GET')
    req.add_header('Authorization', f'Bearer {token}')
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            payload = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        try:
            payload = json.loads(e.read())
            message = payload.get('error') or e.reason
        except Exception:
            message = e.reason
        raise XPortError(f'API returned {e.code}: {message}') from e
    except urllib.error.URLError as e:
        raise XPortError(f'API request failed: {e.reason}') from e
    if not payload.get('ok', True):
        raise XPortError(payload.get('error') or 'API returned ok=false')
    return payload


def post_json(url, token, payload):
    body = json.dumps(payload).encode('utf-8')
    req = urllib.request.Request(url, data=body, method='POST')
    req.add_header('Content-Type', 'application/json')
    if token:
        req.add_header('Authorization', f'Bearer {token}')
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read() or b'{}')
    except urllib.error.HTTPError as e:
        try:
            result = json.loads(e.read())
            message = result.get('error') or e.reason
        except Exception:
            message = e.reason
        raise XPortError(f'HTTP {e.code}: {message}') from e
    except urllib.error.URLError as e:
        raise XPortError(f'request failed: {e.reason}') from e
    if result.get('ok') is not True:
        raise XPortError(result.get('error') or 'request returned ok=false')
    return result


def transcribe_api_media(args):
    media = request_api(args.api_url, args.token, f'/api/media/{urllib.parse.quote(args.media_id, safe="")}', {}).get('media')
    if not media:
        raise XPortError(f'media not found: {args.media_id}')
    if media.get('media_type') not in {'video', 'animated_gif'}:
        raise XPortError(f'media is not video: {args.media_id}')
    token = args.daemon_token or read_daemon_token()
    return post_json(args.daemon_url.rstrip('/') + '/transcribe-media', token, {
        'media_id': media['media_id'],
        'tweet_id': media['tweet_id'],
        'source_url': media.get('source_url'),
        'duration_ms': media.get('duration_ms'),
    })


def read_daemon_token():
    path = os.path.expanduser('~/.xport/secret')
    try:
        with open(path, 'r') as f:
            return f.read().strip()
    except OSError as e:
        raise XPortError('set --daemon-token or ensure ~/.xport/secret is readable') from e


def run_db(args):
    try:
        import psycopg
        from psycopg.rows import dict_row
    except ImportError as e:
        raise XPortError('direct DB reads require psycopg; run with uv --with psycopg[binary] or use --api-url') from e

    with psycopg.connect(args.database_url, row_factory=dict_row, connect_timeout=5) as conn:
        if args.command == 'get':
            row = conn.execute(
                f"select {projection(args.include_raw)} from tweets where tweet_id = %s",
                (args.tweet_id,),
            ).fetchone()
            if not row:
                raise XPortError(f'tweet not found: {args.tweet_id}')
            tweet = json_ready(row)
            if args.include_media:
                tweet['media'] = db_media_for_tweet(conn, args.tweet_id)
            return tweet
        if args.command == 'media':
            return db_media_for_tweet(conn, args.tweet_id, require_tweet=True)
        if args.command == 'media-content':
            if not args.data_url:
                raise XPortError('media-content currently requires --data-url')
            return db_media_content(conn, args.media_id)
        if args.command == 'transcribe':
            raise XPortError('transcribe requires --api-url so the daemon can update the hosted API')
        if args.command == 'stats':
            row = conn.execute(
                """
                select
                  count(*) as tweet_count,
                  min(created_at) as oldest_created_at,
                  max(created_at) as newest_created_at,
                  max(captured_at) as newest_captured_at,
                  count(distinct author_username) as author_count
                from tweets
                """
            ).fetchone()
            return json_ready(row)
        rows = conn.execute(*build_tweet_query(args)).fetchall()
        tweets = [json_ready(row) for row in rows]
        if args.include_media and tweets:
            attach_db_media(conn, tweets)
        if args.command == 'digest':
            return build_digest(tweets, args)
        return tweets


def build_digest(tweets, args):
    author_counts = Counter(tweet.get('author_username') or 'unknown' for tweet in tweets)
    endpoint_counts = Counter(tweet.get('source_endpoint') or 'unknown' for tweet in tweets)
    return {
        'tweet_count': len(tweets),
        'filters': {
            'author': args.author,
            'since': args.since,
            'until': args.until,
            'endpoint': args.endpoint,
            'limit': args.limit,
            'offset': args.offset,
        },
        'top_authors': [
            {'author_username': author, 'tweet_count': count}
            for author, count in author_counts.most_common(20)
        ],
        'top_endpoints': [
            {'source_endpoint': endpoint, 'tweet_count': count}
            for endpoint, count in endpoint_counts.most_common()
        ],
        'tweets': tweets,
    }


def build_tweet_query(args):
    clauses = []
    params = []
    if args.command == 'search' and args.query:
        clauses.append('(text ilike %s or raw::text ilike %s)')
        needle = f'%{args.query}%'
        params.extend([needle, needle])
    if args.author:
        clauses.append('lower(author_username) = lower(%s)')
        params.append(args.author.lstrip('@'))
    if args.since:
        clauses.append('coalesce(created_at, captured_at) >= %s')
        params.append(args.since)
    if args.until:
        clauses.append('coalesce(created_at, captured_at) <= %s')
        params.append(args.until)
    if args.endpoint:
        clauses.append('source_endpoint = %s')
        params.append(args.endpoint)

    where = f"where {' and '.join(clauses)}" if clauses else ''
    sql = f"""
        select {projection(args.include_raw)}
        from tweets
        {where}
        order by coalesce(created_at, captured_at) desc, captured_at desc
        limit %s offset %s
    """
    params.extend([bounded(args.limit, 1, 500), bounded(args.offset, 0, 100000)])
    return sql, params


def projection(include_raw):
    fields = list(FIELDS)
    if include_raw:
        fields.append('raw')
    return ', '.join(fields)


MEDIA_FIELDS = [
    'media_id',
    'tweet_id',
    'media_index',
    'media_type',
    'source_url',
    'alt_text',
    'duration_ms',
    'width',
    'height',
    'transcript_text',
    'transcript_model',
    'transcript_status',
    'transcript_error',
    'transcribed_at',
    'asset_status',
    'asset_mime_type',
    'asset_byte_size',
    'content_sha256',
    'created_at',
    'updated_at',
]


def db_media_for_tweet(conn, tweet_id, require_tweet=False):
    if require_tweet:
        exists = conn.execute('select 1 from tweets where tweet_id = %s', (tweet_id,)).fetchone()
        if not exists:
            raise XPortError(f'tweet not found: {tweet_id}')
    rows = conn.execute(
        f"select {', '.join(MEDIA_FIELDS)} from tweet_media where tweet_id = %s order by media_index asc",
        (tweet_id,),
    ).fetchall()
    return [json_ready(row) for row in rows]


def attach_db_media(conn, tweets):
    tweet_ids = [tweet['tweet_id'] for tweet in tweets]
    rows = conn.execute(
        f"select {', '.join(MEDIA_FIELDS)} from tweet_media where tweet_id = any(%s) order by tweet_id, media_index asc",
        (tweet_ids,),
    ).fetchall()
    by_tweet = {tweet_id: [] for tweet_id in tweet_ids}
    for row in rows:
        item = json_ready(row)
        by_tweet.setdefault(item['tweet_id'], []).append(item)
    for tweet in tweets:
        tweet['media'] = by_tweet.get(tweet['tweet_id'], [])


def db_media_content(conn, media_id):
    row = conn.execute(
        'select media_id, asset_mime_type, asset_bytes from tweet_media where media_id = %s',
        (media_id,),
    ).fetchone()
    if not row:
        raise XPortError(f'media not found: {media_id}')
    raw = row['asset_bytes']
    if raw is None:
        raise XPortError(f'media asset not stored: {media_id}')
    if isinstance(raw, memoryview):
        raw = raw.tobytes()
    elif not isinstance(raw, bytes):
        raw = bytes(raw)
    mime_type = row['asset_mime_type'] or 'application/octet-stream'
    return {
        'media_id': row['media_id'],
        'data_url': f'data:{mime_type};base64,{base64.b64encode(raw).decode("ascii")}',
    }


def bounded(value, minimum, maximum):
    return min(max(value, minimum), maximum)


def json_ready(value):
    if isinstance(value, dict):
        return {key: json_ready(item) for key, item in value.items()}
    if isinstance(value, list):
        return [json_ready(item) for item in value]
    if isinstance(value, datetime):
        return value.astimezone(timezone.utc).isoformat().replace('+00:00', 'Z')
    return value


def write_output(result, jsonl=False):
    if jsonl and isinstance(result, list):
        for item in result:
            print(json.dumps(item, ensure_ascii=False, separators=(',', ':')))
        return
    print(json.dumps(result, ensure_ascii=False, indent=2))


class XPortError(Exception):
    pass


if __name__ == '__main__':
    raise SystemExit(main())
