# PostgreSQL database connection (main)
DATABASE_URL=postgresql://user:password@host:port/dbname

# PostgreSQL database connection (content)
CONTENT_DATABASE_URL=postgresql://user:password@host:port/dbname

# Ingest token for API authentication
INGEST_TOKEN=your_ingest_token_here

# XPort API URL (hosted ingestion endpoint)
XPORT_API_URL=http://your-api-url

# XPort ingest token (may differ from INGEST_TOKEN)
XPORT_INGEST_TOKEN=your_ingest_token_here
